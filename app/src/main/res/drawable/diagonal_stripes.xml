<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <rotate
            android:fromDegrees="45"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <stroke
                    android:width="1dp"
                    android:color="#10E10600" />
                <size
                    android:width="20dp"
                    android:height="20dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
