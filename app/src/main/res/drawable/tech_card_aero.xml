<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#00001F" android:endColor="#000D33" android:angle="135"/>
        </shape>
    </item>
    <!-- Blue sweep from right -->
    <item android:left="80dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#00003399" android:endColor="#440066FF" android:angle="0"/>
        </shape>
    </item>
    <!-- Top blue bar -->
    <item android:bottom="120dp">
        <shape android:shape="rectangle">
            <solid android:color="#0055CC"/>
        </shape>
    </item>
    <!-- Second bar -->
    <item android:top="12dp" android:bottom="108dp">
        <shape android:shape="rectangle">
            <solid android:color="#003399"/>
        </shape>
    </item>
    <!-- Horizontal lines (speed effect) -->
    <item android:top="25dp" android:bottom="105dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#220066FF" android:endColor="#000066FF" android:angle="0"/>
        </shape>
    </item>
    <item android:top="40dp" android:bottom="90dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#110044CC" android:endColor="#000044CC" android:angle="0"/>
        </shape>
    </item>
    <!-- Dark left overlay -->
    <item android:right="160dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#AA000000" android:endColor="#00000000" android:angle="0"/>
        </shape>
    </item>
</layer-list>
