<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <View
        android:id="@+id/topStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/gradient_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topStripe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/headerAccentBar"
            android:layout_width="4dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/racing_stripe" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F1 BASICS"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="@font/titillium_web"
                android:textFontWeight="700"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everything a new fan must know"
                android:textColor="#999999"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter" />
        </LinearLayout>

        <!-- Basic / Detailed toggle -->
        <FrameLayout
            android:id="@+id/modeToggleContainer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/toggle_track_bg"
            android:padding="3dp"
            android:visibility="gone">

            <!-- Sliding pill indicator -->
            <View
                android:id="@+id/toggleIndicator"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:background="@drawable/toggle_track_bg" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/toggleBasic"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:text="Basic"
                    android:textSize="12sp"
                    android:fontFamily="@font/barlow_condensed"
                    android:textFontWeight="700"
                    android:letterSpacing="0.06"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/toggleDetailed"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:text="Detailed"
                    android:textSize="12sp"
                    android:fontFamily="@font/barlow_condensed"
                    android:textFontWeight="700"
                    android:letterSpacing="0.06"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Tab bar -->
    <HorizontalScrollView
        android:id="@+id/tabScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="12dp" />
    </HorizontalScrollView>

    <!-- Content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/basicsListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tabScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
