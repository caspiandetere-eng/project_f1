<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/topStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/gradient_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topStripe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:layout_marginEnd="14dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/headerAccentBar"
            android:layout_width="4dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/gradient_red" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F1 IMPACT"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:fontFamily="@font/titillium_web"
                android:textFontWeight="700"
                android:letterSpacing="0.1"
                android:shadowColor="#E10600"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="20" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Technology Shaping Tomorrow"
                android:textColor="#999999"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!-- AUTOMOTIVE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAutomotive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="#E10600"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="🚗"
                            android:textSize="28sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:text="AUTOMOTIVE"
                            android:textColor="#E10600"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/arrowAutomotive"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_arrow"
                            android:tint="#E10600"
                            android:rotation="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentAutomotive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/gradient_red"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="• MGU-H &amp; MGU-K hybrid systems\n• 50%+ thermal efficiency engines\n• AWD torque distribution systems\n• Brake-by-wire technology\n• Advanced aerodynamic simulation tools"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEDICAL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMedical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="#40E10600"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="🏥"
                            android:textSize="28sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:text="MEDICAL"
                            android:textColor="#E10600"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/arrowMedical"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_arrow"
                            android:tint="#E10600"
                            android:rotation="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentMedical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/gradient_red"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="• Hospital handover protocols (40% error reduction)\n• Biometric monitoring gloves\n• Carbon fiber prosthetics\n• Real-time physiological data systems\n• Impact-absorbing HANS device evolution"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SUSTAINABILITY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSustainability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="#40E10600"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="♻️"
                            android:textSize="28sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:text="SUSTAINABILITY"
                            android:textColor="#E10600"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/arrowSustainability"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_arrow"
                            android:tint="#E10600"
                            android:rotation="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSustainability"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/gradient_red"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="• 100% sustainable fuels by 2026\n• Drop-in e-fuels from CO2\n• Flax fiber composites\n• Net-zero carbon operations by 2030\n• Circular economy component mandates"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ECONOMIC -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEconomic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="#40E10600"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="💼"
                            android:textSize="28sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:text="ECONOMIC"
                            android:textColor="#E10600"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/arrowEconomic"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_arrow"
                            android:tint="#E10600"
                            android:rotation="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentEconomic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/gradient_red"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="• €100M+ regional economic impact\n• STEM talent pipeline\n• Global tourism boost\n• $2.6B annual broadcast revenue\n• 500M+ global fan base growth"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MATERIALS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMaterials"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="#40E10600"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="🔬"
                            android:textSize="28sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:text="MATERIALS"
                            android:textColor="#E10600"
                            android:textSize="18sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/arrowMaterials"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_expand_arrow"
                            android:tint="#E10600"
                            android:rotation="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentMaterials"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/gradient_red"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="• Zylon anti-ballistic protection\n• Ceramic thermal coatings (1000°C)\n• Carbon fiber composites\n• Recycled carbon fiber mandates\n• Lightweight titanium alloy structures"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
