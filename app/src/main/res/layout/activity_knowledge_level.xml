<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f1_black_background">

    <!-- Top accent stripe -->
    <View
        android:id="@+id/topStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/gradient_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Settings button -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_glass_red"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Settings"
        android:elevation="8dp"
        app:tint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topStripe">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="80dp"
            android:paddingBottom="40dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/gradient_red" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR F1 LEVEL"
                        android:textColor="@color/text_primary_white"
                        android:textSize="28sp"
                        android:fontFamily="@font/titillium_web"
                        android:textFontWeight="700"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Pick the level that matches your F1 knowledge"
                        android:textColor="@color/text_secondary_gray"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter" />
                </LinearLayout>
            </LinearLayout>

            <!-- XP explainer card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- XP header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="HOW XP WORKS"
                            android:textColor="@color/f1_red_accent"
                            android:textSize="11sp"
                            android:fontFamily="@font/barlow_condensed"
                            android:textFontWeight="700"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20 LEVELS TOTAL"
                            android:textColor="#444444"
                            android:textSize="10sp"
                            android:fontFamily="@font/barlow_condensed"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <!-- XP row: score >= 70 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="⬆"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="#0A2A0A"
                            android:textColor="#2ECC71" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Score ≥ 70%"
                                android:textColor="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full XP earned · possible level up"
                                android:textColor="#555555"
                                android:textSize="11sp"
                                android:fontFamily="@font/inter" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- XP row: score 40-69 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="→"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="#1A1200"
                            android:textColor="#FFAA00" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Score 40–69%"
                                android:textColor="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Half XP · no level change"
                                android:textColor="#555555"
                                android:textSize="11sp"
                                android:fontFamily="@font/inter" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- XP row: score < 40 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="⬇"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="#2A0A0A"
                            android:textColor="#E74C3C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Score &lt; 40%"
                                android:textColor="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No XP · demoted 1 level"
                                android:textColor="#555555"
                                android:textSize="11sp"
                                android:fontFamily="@font/inter" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="14dp"
                android:text="SELECT YOUR STARTING TIER"
                android:textColor="#444444"
                android:textSize="11sp"
                android:fontFamily="@font/barlow_condensed"
                android:textFontWeight="700"
                android:letterSpacing="0.15" />

            <!-- ROOKIE card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRookie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0E1A0E"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#1A4A1A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Badge -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#1A4A1A">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏁"
                            android:textSize="22sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/rookie"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/titillium_web"
                                android:textFontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="L1 – L5"
                                android:textColor="#2ECC71"
                                android:textSize="11sp"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:background="#0A2A0A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/rookie_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="General content · race basics · standings"
                            android:textColor="#2ECC71"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="→"
                        android:textColor="#2ECC71"
                        android:textSize="20sp"
                        android:fontFamily="@font/barlow_condensed" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CASUAL card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCasual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0E130E"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#1A3A1A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Badge -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#1A3A1A">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏎"
                            android:textSize="22sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/casual_fan"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/titillium_web"
                                android:textFontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="L6 – L10"
                                android:textColor="#66BB6A"
                                android:textSize="11sp"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:background="#0D2A0D" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/casual_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Richer driver cards · more standings rows"
                            android:textColor="#66BB6A"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="→"
                        android:textColor="#66BB6A"
                        android:textSize="20sp"
                        android:fontFamily="@font/barlow_condensed" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ENTHUSIAST card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEnthusiast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#130E08"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#3A2A0A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Badge -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#3A2A0A">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚙️"
                            android:textSize="22sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/enthusiast"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/titillium_web"
                                android:textFontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="L11 – L15"
                                android:textColor="#FFAA00"
                                android:textSize="11sp"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:background="#2A1A00" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/enthusiast_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Career stats · constructor data · records"
                            android:textColor="#FFAA00"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="→"
                        android:textColor="#FFAA00"
                        android:textSize="20sp"
                        android:fontFamily="@font/barlow_condensed" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- INSIDER card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInsider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0D0A14"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#2A1A4A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Badge -->
                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#2A1A4A">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆"
                            android:textSize="22sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/paddock_insider"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/titillium_web"
                                android:textFontWeight="700" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="L16 – L20"
                                android:textColor="#BB86FC"
                                android:textSize="11sp"
                                android:fontFamily="@font/barlow_condensed"
                                android:textFontWeight="700"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:background="#1A0A2A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/insider_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Full telemetry · circuit speed data · all content"
                            android:textColor="#BB86FC"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="→"
                        android:textColor="#BB86FC"
                        android:textSize="20sp"
                        android:fontFamily="@font/barlow_condensed" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="You can always change your level by taking the quiz in Settings."
                android:textColor="#444444"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
