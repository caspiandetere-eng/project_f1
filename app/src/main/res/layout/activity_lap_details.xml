<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <View
        android:id="@+id/topStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/gradient_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topStripe">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/rootContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="32dp">

                <!-- Header -->
                <LinearLayout
                    android:id="@+id/header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="←"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/bg_glass_card"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <View
                        android:id="@+id/headerAccentBar"
                        android:layout_width="4dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="14dp"
                        android:background="@color/f1_red_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CIRCUIT DATABASE"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:fontFamily="@font/titillium_web"
                            android:textFontWeight="700"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap any circuit to reveal the track map"
                            android:textColor="#999999"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Dynamic content will be added here -->
                <LinearLayout
                    android:id="@+id/circuitsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
