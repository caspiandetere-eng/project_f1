<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f1_black_background">

    <View
        android:id="@+id/topStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/gradient_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topStripe">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/racing_stripe" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/titillium_web"
                    android:textFontWeight="700"
                    android:letterSpacing="0.15"
                    android:shadowColor="#80000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:text="@string/join_the_grid"
                    android:textColor="@color/text_primary_white"
                    android:textSize="36sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="@string/signup_subtitle"
                android:textColor="@color/text_secondary_gray"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerLayout" />

            <!-- Profile Picture Section -->
            <LinearLayout
                android:id="@+id/profilePicSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <!-- Avatar circle -->
                <ImageView
                    android:id="@+id/ivProfilePic"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_foreground"
                    android:contentDescription="Profile picture" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="CHOOSE PROFILE PICTURE"
                    android:textColor="#999999"
                    android:textSize="11sp"
                    android:fontFamily="@font/barlow_condensed"
                    android:letterSpacing="0.15" />

                <!-- 3 option buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickDriver"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Driver"
                        android:textSize="12sp"
                        android:fontFamily="@font/barlow_condensed"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#1A1A1A"
                        app:strokeColor="#E10600"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickGallery"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Gallery"
                        android:textSize="12sp"
                        android:fontFamily="@font/barlow_condensed"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#1A1A1A"
                        app:strokeColor="#E10600"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="@string/full_name"
                android:textColorHint="@color/text_secondary_gray"
                app:boxBackgroundColor="@color/f1_card_dark"
                app:boxStrokeColor="@color/f1_red_accent"
                app:hintTextColor="@color/f1_red_accent"
                app:layout_constraintTop_toBottomOf="@id/profilePicSection">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary_white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/email"
                android:textColorHint="@color/text_secondary_gray"
                app:boxBackgroundColor="@color/f1_card_dark"
                app:boxStrokeColor="@color/f1_red_accent"
                app:hintTextColor="@color/f1_red_accent"
                app:layout_constraintTop_toBottomOf="@id/tilName">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary_white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/password"
                android:textColorHint="@color/text_secondary_gray"
                app:boxBackgroundColor="@color/f1_card_dark"
                app:boxStrokeColor="@color/f1_red_accent"
                app:hintTextColor="@color/f1_red_accent"
                app:layout_constraintTop_toBottomOf="@id/tilEmail"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_secondary_gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary_white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/barlow_condensed"
                android:textFontWeight="700"
                android:letterSpacing="0.1"
                android:text="@string/continue_text"
                android:textColor="@color/text_primary_white"
                android:textSize="16sp"
                app:backgroundTint="#E10600"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/tilPassword" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForgotPassword"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/barlow_condensed"
                android:text="Forgot Password?"
                android:textColor="@color/text_secondary_gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnContinue" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
