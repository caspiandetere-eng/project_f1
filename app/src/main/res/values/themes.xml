<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Project_f1" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#E10600</item>
        <item name="colorPrimaryVariant">#B00500</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:colorBackground">#0D0D0D</item>
        <item name="android:statusBarColor">#0D0D0D</item>
        <item name="android:navigationBarColor">#0D0D0D</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Project_f1" parent="Base.Theme.Project_f1">
        <item name="android:forceDarkAllowed">true</item>
    </style>

    <style name="NavItemTextAppearance" parent="@android:style/TextAppearance">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
    <style name="BottomSheetTheme" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">#1A1A1A</item>
        <item name="shapeAppearance">@style/BottomSheetShape</item>
    </style>

    <style name="BottomSheetShape" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>